<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  PrivacyInfo.xcprivacy
  OshiUI

  Copyright © 2026 Davud Gunduz. All rights reserved.

  Apple Privacy Manifest for OshiUI framework.
  OshiUI does not collect, track, or transmit any user data.
-->
<plist version="1.0">
<dict>
    <!-- OshiUI does not engage in tracking -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No tracking domains -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- No user data is collected -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- Required API declarations -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!--
          UserDefaults is accessed for persisting user theme preferences
          (e.g., selected color scheme, accessibility overrides).
        -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
